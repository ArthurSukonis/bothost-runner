# BotHost Runner Environment Variables

# Server
PORT=8080
NODE_ENV=production

# Security
RUNNER_SHARED_SECRET=your-shared-secret-here

# Web App Integration
WEB_APP_URL=https://your-app.lovable.app

# Optional: Supabase (for future integration)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
